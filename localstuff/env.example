APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8787

# ──────────────────────────────────────────────────────────────────────────────
# KI-Provider-Auswahl (kommagetrennt, Reihenfolge = Standard-Provider zuerst)
# Moegliche Werte: gemini | openai | azure_openai | azure_cognitive
# Beispiele:
#   Nur Gemini:              AI_PROVIDER=gemini
#   Gemini + Azure OpenAI:   AI_PROVIDER=gemini,azure_openai
#   Alle:                    AI_PROVIDER=gemini,openai,azure_openai,azure_cognitive
# ──────────────────────────────────────────────────────────────────────────────
AI_PROVIDER=gemini

# ── Google Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── OpenAI (direkt) ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# ── Azure OpenAI (Microsoft Foundry / Azure AI Services) ─────────────────────
# Endpoint aus dem Azure-Portal (z. B. https://<resource>.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=
# API-Key aus dem Azure-Portal
AZURE_OPENAI_API_KEY=
# Deployment-Name (nicht der Modell-Name, sondern die Bereitstellung)
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
# API-Version – aktuelle stabile Version beibehalten
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── Azure Cognitive Services (cognitiveservices.azure.com) ────────────────────
AZURE_COGNITIVE_ENDPOINT=
AZURE_COGNITIVE_API_KEY=
AZURE_COGNITIVE_DEPLOYMENT=gpt-5-mini
AZURE_COGNITIVE_API_VERSION=2025-04-01-preview

# ── KI-Retry bei Throttling (503/429) ────────────────────────────────────────
# Maximale Anzahl an Wiederholungsversuchen pro KI-Aufruf (0 = kein Retry)
AI_RETRY_MAX_ATTEMPTS=3
# Wartezeit in Sekunden vor dem ersten Retry
AI_RETRY_INITIAL_DELAY=10
# Multiplikator fuer Exponential-Backoff
AI_RETRY_BACKOFF_FACTOR=2.0
# Maximale Wartezeit zwischen zwei Retries in Sekunden
AI_RETRY_MAX_DELAY=60

FFMPEG_PATH=./tools/ffmpeg/bin/ffmpeg.exe
FFPROBE_PATH=./tools/ffmpeg/bin/ffprobe.exe
AUTO_EDITOR_PATH=./tools/auto-editor/auto-editor-windows-x86_64.exe

# ── Auto-Editor Schnitt-Parameter ────────────────────────────────────────────
AUTO_EDITOR_AUDIO_EDIT=audio:threshold=0.03
AUTO_EDITOR_MOTION_EDIT=motion:threshold=0.08
AUTO_EDITOR_COMBINED_EDIT=(or audio:0.03 motion:0.08)
AUTO_EDITOR_MARGIN=0.5s

WORKSPACE_ROOT=./workspace
UPLOAD_DIR=./workspace/uploads
NORMALIZED_DIR=./workspace/normalized
CUT_DIR=./workspace/cut
FRAMES_DIR=./workspace/frames
AI_OUTPUT_DIR=./workspace/ai-output
RENDER_OUTPUT_DIR=./workspace/output

DEFAULT_LANGUAGE=de
OUTPUT_VIDEO_WIDTH=1920
OUTPUT_VIDEO_HEIGHT=1080
FRAME_EXTRACTION_FPS=0.333
SCENE_DIFF_THRESHOLD=0.08
MIN_SCENE_SECONDS=1.0

# ── Parallelitaet ─────────────────────────────────────────────────────────────
MAX_PARALLEL_LANGUAGES=4
FFMPEG_THREADS_PER_JOB=2

AUTO_EDITOR_AUDIO_EDIT=audio:threshold=0.03
AUTO_EDITOR_MOTION_EDIT=motion:threshold=0.08
AUTO_EDITOR_COMBINED_EDIT=(or audio:0.03 motion:0.08)
AUTO_EDITOR_MARGIN=0.5s

MAX_PARALLEL_LANGUAGES=4
FFMPEG_THREADS_PER_JOB=2
